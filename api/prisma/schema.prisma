generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Job {
    id            String    @id @default(cuid())
    issueUrl      String
    repoUrl       String?
    issueTitle    String?
    status        JobStatus @default(PENDING)
    testCode      String?
    fixCode       String?
    fixedFilePath String?
    prUrl         String?
    errorMessage  String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
}

enum JobStatus {
    PENDING
    RUNNING
    SUCCESS
    FAILED
}
